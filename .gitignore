# ── Secrets — NEVER commit these ─────────────────────────────────────────────
.env
**/.env
*.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
dist/
*.egg-info/
.eggs/
*.pyi_typestubs

# ── MLflow / tracking artifacts ───────────────────────────────────────────────
