# ── Platform ────────────────────────────────────────────────────────────────
GENIE_LLM_PROVIDER=gpt_oss
GENIE_API_HOST=0.0.0.0
GENIE_API_PORT=2003
GENIE_API_KEY=
GENIE_DEBUG=false
GENIE_LOG_LEVEL=INFO

# ── Feature gates ─────────────────────────────────────────────────────────────
GENIE_ENABLE_RAG=true
GENIE_ENABLE_TRACKING=true
GENIE_ENABLE_HITL=false
GENIE_ENABLE_GUARDS=true
GENIE_ENABLE_ROUTER=true

# ── RAG ───────────────────────────────────────────────────────────────────────
GENIE_RAG_MODE=local
GENIE_RAG_SERVICE_URL=http://localhost:2004
GENIE_RAG_TIMEOUT_SECONDS=30.0
GENIE_RAG_MAX_RETRIES=3

# ── Tracking (MLflow) ─────────────────────────────────────────────────────────
GENIE_MLFLOW_TRACKING_URI=http://localhost:2001
GENIE_MLFLOW_EXPERIMENT_NAME=genie-platform

# ── Content guards (llm-guard; requires `uv sync --extra guards`) ─────────────
# GENIE_GUARD_BAN_TOPICS=violence,self-harm,hate speech,illegal weapons
GENIE_GUARD_PII=true
GENIE_GUARD_FAIL_OPEN=false

# ── Distributed agents (A2A + registry discovery) ──────────────────────────────
GENIE_AGENT_MODE=distributed
GENIE_REGISTRY_URL=http://127.0.0.1:2005
# GENIE_REGISTRY_AUTH_TOKEN=
GENIE_REGISTRY_TTL_SECONDS=90
GENIE_REGISTRY_HEARTBEAT_SECONDS=30
GENIE_AGENT_REFRESH_SECONDS=30

# ── Multi-store memory ──────────────────────────────────────────────────────────
# in_memory (zero-dep) or mongo (durable). Mongo needs `uv sync --extra memory-mongo`.
GENIE_MEMORY_BACKEND=in_memory
GENIE_MONGODB_URI=mongodb://localhost:27017
GENIE_MONGODB_DB=agent_memory
# GENIE_REDIS_URL=redis://localhost:6379/0          # hot blackboard mirror (extra memory-redis)
# GENIE_MILVUS_URI=http://localhost:19530           # remote Milvus (extra memory-vector)
GENIE_MILVUS_DB_PATH=./milvus_local.db
# GENIE_POSTGRES_DSN=postgresql://user:pass@localhost:5432/genie   # commit store (extra memory-postgres)
GENIE_OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Router tuning ─────────────────────────────────────────────────────────────
GENIE_ROUTER_INTENT_CLASSIFIER=true

# ── LLM provider credentials (used by agent services + embeddings) ─────────────
# Agent services (genie-agent-sdk) and the embedding client read these.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
