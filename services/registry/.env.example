# Mongo connection backing the registry store
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=agent_memory

# Service bind port
REGISTRY_PORT=2005

# Liveness window (seconds). A record older than this is treated as dead and is
# also physically removed by the Mongo TTL index.
REGISTRY_TTL_SECONDS=90

# Optional bearer token guarding all routes except /health. Leave blank for
# local dev (the auth check becomes a no-op).
REGISTRY_AUTH_TOKEN=
