# --- LLM (langchain-openai / OpenAI-compatible) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- MCP tool server ---
# The example MCP server runs on port 2002 with streamable_http transport.
MCP_SERVER_URL=http://127.0.0.1:2002/mcp
MCP_TRANSPORT=streamable_http

# --- Registry / discovery ---
REGISTRY_URL=http://127.0.0.1:2005

# --- This agent's bind host/port (set AGENT_PORT per agent) ---
# weather=2010, outage=2011, rag=2012
AGENT_HOST=127.0.0.1
AGENT_PORT=2010
