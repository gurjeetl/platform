# --- LLM (langchain-openai / OpenAI-compatible) ---
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TEMPERATURE=0

# --- MCP (optional; agent skips MCP when MCP_SERVER_URL is unset) ---
MCP_SERVER_URL=
MCP_SERVER_NAME=default
MCP_TRANSPORT=sse
MCP_AUTH_TOKEN=
MCP_TIMEOUT=30.0

# --- Harness / registration ---
AGENT_HOST=127.0.0.1
AGENT_PORT=8010
AGENT_ADVERTISE_HOST=
AGENT_ADVERTISE_PORT=
REGISTRY_URL=http://127.0.0.1:2005
REGISTRY_AUTH_TOKEN=
REGISTRY_HEARTBEAT_SECONDS=30
REGISTRY_TIMEOUT_S=3
# Optional bearer token guarding POST /a2a
AGENT_INVOKE_TOKEN=
